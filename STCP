!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sakura Japanese Website</title>
  </head>
  <body>
    <!-- 
      
      <h1> = opening tag
      Welcome to Sakura Japanese Dining = innerText
      </h1> =  closing tag

      All together is a HTML element
    -->
    <h1>Welcome to Sakura Japanese Dining</h1>
    <h2>Japanese Food So Authentic, Anymore You Would Have to Fly to Japan</h2>
    <p>
      The best japanese restuarant in town! Promotion is on.
    </p>
    <h2>Our Recommended Dishes</h2>
    <ul>
      <li>Overly Fried Chicken with Too Much Breading</li>
      <li>Overpriced Raw Fish</li>
      <li>Steamed Egg</li>
    </ul>

    <p>Make a <a href="reserve.html">reservation</a> in advance</p>

    <h2>Our Best Selling Items</h2>
    <ol>
      <li>Grilled Salmon</li>
      <li>Salmon Sushi</li>
      <li>Ramen</li>
    </ol>

    <h2>Opening Hours</h2>
    <table>
      <thead>
        <tr>
          <th>Day</th>
          <th>Opens At</th>
          <th>Closes At</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Weekdays</td>
          <td>11:00am</td>
          <td>10:30pm</td>
        </tr>
        <tr>
          <td>Saturday</td>
          <td>1:00pm</td>
          <td>3:30am</td>
        </tr>
        <tr>
          <td>Sunday</td>
          <td>10:30am</td>
          <td>8:30pm</td>
        </tr>
      </tbody>
    </table>

    <!-- some html tags are self-closing -->
    <img src="japanese-food.jpg" />
    <!-- if a URL does not begin with a HTTP
    or HTTPs, then it is relative.Relative means we
    are looking for the file in the SAME folder
    as the .html file
  
    if a URL begins with HTTP or HTTPS then it is absolute. Absolute means the URL will always
    refer to that file
    -->
    <img
      src="https://rimage.gnst.jp/livejapan.com/public/article/detail/a/00/00/a0000370/img/basic/a0000370_main.jpg"
    />
    <img src="/images/japanese-food-2.jpg" />

    <a href="https://www.japan.travel/en/sg/"> Japan Tourism Board </a>
    <!-- go to the `about-us.html` in the same DIRECTORY as `index.html` -->
    <a href="about-us.html">About Us</a>

    <!-- root relative URL -->
    <!-- go to the `page2.html` IN the starting directory (aka root) of the project -->
    <a href="/page2.html">Page 2</a>
  </body>
</html>
